  tripFilterToggleLeft: { flexDirection: 'row', alignItems: 'center', gap: 8 },
  tripFilterIcon: { width: 28, height: 28, borderRadius: 14, backgroundColor: GOLD_LIGHT, alignItems: 'center', justifyContent: 'center' },
  tripFilterToggleText: { fontSize: 14, fontWeight: '700', color: '#1e293b' },
  tripFilterBadge: { backgroundColor: GOLD, minWidth: 18, height: 18, borderRadius: 9, alignItems: 'center', justifyContent: 'center', paddingHorizontal: 5 },
