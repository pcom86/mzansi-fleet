  tripFilterResults: { fontSize: 12, color: '#94a3b8', paddingHorizontal: 14, paddingBottom: 8, marginTop: -4 },
  tripFilterSection: { marginBottom: 6 },
  tripFilterSectionHdr: { flexDirection: 'row', alignItems: 'center', gap: 6, paddingHorizontal: 14, marginBottom: 6 },
  tripFilterSectionLabel: { fontSize: 11, fontWeight: '700', color: '#94a3b8', textTransform: 'uppercase', letterSpacing: 0.5 },
  tripFilterChipRow: { paddingHorizontal: 14, gap: 6 },
  tfChip: { flexDirection: 'row', alignItems: 'center', gap: 5, paddingVertical: 7, paddingHorizontal: 14, borderRadius: 20, borderWidth: 1.5, borderColor: '#e2e8f0', backgroundColor: '#f8fafc' },
  tfChipTxt: { fontSize: 12, fontWeight: '600', color: '#94a3b8' },
