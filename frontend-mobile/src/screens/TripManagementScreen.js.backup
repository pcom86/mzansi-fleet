  // ── Add Vehicle Modal extras ──
  fieldLabel: { fontSize: 13, fontWeight: '600', color: '#334155', marginTop: 16, marginBottom: 8 },
  noItems: { fontSize: 13, color: '#94a3b8', fontStyle: 'italic', marginBottom: 12 },
