{
  "expo": {
    "name": "MzansiFleet App",
    "slug": "mzansifleet-app",
    "version": "0.1.0",
    "jsEngine": "jsc",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "apiUrl": "http://10.12.26.164:5000/api",
      "eas": {
        "projectId": "2bcdc50c-c61e-4d29-b4c0-00643c195802"
      }
    },
    "android": {
      "package": "com.pcom86.mzansifleetapp",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.NFC"
      ]
    },
    "ios": {
      "infoPlist": {
        "NFCReaderUsageDescription": "This app uses NFC to process card payments at the point of sale."
      }
    },
    "plugins": [
      "expo-secure-store",
      "react-native-nfc-manager",
      "expo-av"
    ]
  }
}
