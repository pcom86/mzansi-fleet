{
  "AI": {
    "Enabled": true,
    "DefaultModel": "gpt-4",
    "MaxTokens": 500,
    "Temperature": 0.7
  },
  "OpenAI": {
    "ApiKey": "your-openai-api-key-here",
    "BaseUrl": "https://api.openai.com/v1/",
    "DefaultModel": "gpt-4"
  },
  "AzureCognitiveServices": {
    "ApiKey": "your-azure-cognitive-services-key",
    "Region": "your-azure-region",
    "SpeechEndpoint": "https://your-region.stt.speech.microsoft.com/",
    "TranslatorEndpoint": "https://api.cognitive.microsofttranslator.com/"
  },
  "GoogleMaps": {
    "ApiKey": "your-google-maps-api-key",
    "BaseUrl": "https://routes.googleapis.com/"
  },
  "AzureTranslator": {
    "ApiKey": "your-azure-translator-key",
    "Region": "your-azure-region"
  },
  "MachineLearning": {
    "ModelPath": "./models/",
    "Enabled": true,
    "PredictionThreshold": 0.7
  },
  "FraudDetection": {
    "Enabled": true,
    "RiskThreshold": 0.7,
    "MaxTransactionAmount": 10000
  },
  "RouteOptimization": {
    "Enabled": true,
    "Provider": "Google",
    "MaxWaypoints": 25
  },
  "DemandForecasting": {
    "Enabled": true,
    "HistoricalDays": 30,
    "PredictionDays": 7,
    "ModelType": "LinearRegression"
  },
  "Chatbot": {
    "Enabled": true,
    "Provider": "OpenAI",
    "MaxContextLength": 10,
    "WelcomeMessage": "Hello! I'm your Mzansi Fleet assistant. How can I help you today?"
  },
  "SpeechRecognition": {
    "Enabled": true,
    "Provider": "Azure",
    "Language": "en-US",
    "MaxAudioLength": 30
  },
  "Translation": {
    "Enabled": true,
    "Provider": "Azure",
    "DefaultSourceLanguage": "auto",
    "SupportedLanguages": ["en", "af", "zu", "xh", "st", "ts", "ns"]
  }
}
